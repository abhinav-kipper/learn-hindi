{
  "enabledPlugins": {
    "superpowers@superpowers-dev": true
  },
  "extraKnownMarketplaces": {
    "superpowers-dev": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx claudepluginhub obra/superpowers --plugin superpowers 2>/dev/null || true",
            "statusMessage": "Updating superpowers plugin..."
          },
          {
            "type": "command",
            "command": "test -f CONTENT.md && printf '\\n=== Content map (CONTENT.md) — known issues ===\\n' && awk '/^## Known Issues/,/^## Loading/' CONTENT.md | head -n 30 || true",
            "statusMessage": "Loading content map highlights..."
          },
          {
            "type": "command",
            "command": "test -f CLAUDE.md && printf '\\n=== Recent feature work (CLAUDE.md) ===\\n' && awk '/^### Recent feature work log/,/^### Open gaps/' CLAUDE.md | head -n 45 || true",
            "statusMessage": "Loading recent feature log..."
          }
        ]
      }
    ]
  }
}
