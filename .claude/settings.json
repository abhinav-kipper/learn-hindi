{
  "enabledPlugins": {
    "superpowers@superpowers-dev": true
  },
  "extraKnownMarketplaces": {
    "superpowers-dev": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx claudepluginhub obra/superpowers --plugin superpowers 2>/dev/null || true",
            "statusMessage": "Updating superpowers plugin..."
          }
        ]
      }
    ]
  }
}
