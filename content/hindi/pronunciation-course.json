    {
      "id": "retroflex",
      "order": 3,
      "title": "Curl your tongue (T, D)",
      "subtitle": "moordhanya",
      "goal": "Master the retroflex T and D, tongue curled back, versus the soft dental t and d.",
      "intro": "Hindi has TWO t's and two d's. The soft ones (t, d) touch your teeth, like Spanish. The hard ones (T, D) curl your tongue back to the roof of your mouth, that's the typical 'Indian accent' sound. Listen for where the tongue goes.",
      "cards": [
        {
          "id": "r-t-soft",
          "grapheme": "t",
          "dev": "त",
          "hint": "soft 't', tongue on the teeth",
          "anchor": {
