    {
      "id": "aspiration",
      "order": 2,
      "title": "The puff of air (kh, gh, th…)",
      "subtitle": "mahaapraan",
      "goal": "Learn the aspirated sounds, the same letter, but with a strong puff of breath.",
      "intro": "Here's a sound English doesn't track: the puff of air. 'k' has no puff, but 'kh' bursts with breath. Hold your hand to your mouth, you should feel air on the 'h' ones. These change the word completely.",
      "cards": [
        {
          "id": "a-k",
          "grapheme": "k / kh",
          "say": "k, kh",
          "dev": "क, ख",
          "hint": "k (no air) vs kh (big puff)",
          "anchor": {
            "word": "khaana",
            "dev": "खाना",
            "en": "food / to eat"
          },
          "kind": "consonant"
        },
        {
          "id": "a-g",
          "grapheme": "g / gh",
          "say": "g, gh",
          "dev": "ग, घ",
          "hint": "g vs gh (breathy g)",
          "anchor": {
            "word": "ghar",
            "dev": "घर",
            "en": "home"
          },
          "kind": "consonant"
        },
        {
          "id": "a-c",
          "grapheme": "ch / chh",
          "say": "ch, chh",
          "dev": "च, छ",
          "hint": "ch vs chh (puffed ch)",
          "anchor": {
            "word": "chhata",
            "dev": "छाता",
            "en": "umbrella"
          },
          "kind": "consonant"
        },
        {
          "id": "a-p",
          "grapheme": "p / ph",
          "say": "p, ph",
          "dev": "प, फ",
          "hint": "p vs ph (puff, NOT 'f')",
          "anchor": {
            "word": "phal",
            "dev": "फल",
            "en": "fruit"
          },
          "kind": "consonant"
        },
        {
          "id": "a-b",
          "grapheme": "b / bh",
          "say": "b, bh",
          "dev": "ब, भ",
          "hint": "b vs bh (breathy b)",
          "anchor": {
            "word": "bhai",
            "dev": "भाई",
            "en": "brother"
          },
          "kind": "consonant"
        },
        {
          "id": "a-d",
          "grapheme": "d / dh",
          "say": "d, dh",
          "dev": "द, ध",
          "hint": "soft d vs dh (breathy d)",
          "anchor": {
